{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://velocit.ee/schemas/vne/output/1.0",
  "title": "VNE Output Manifest",
  "description": "Written by VNE on success — read by VSE. Extends the shared engine manifest with a 'vne' record under engines. Two modes are valid: 'deploy' (VNE provisioned an OPNsense VM and configured the network) and 'join' (VNE joined an existing network and recorded its observed state).",
  "type": "object",
  "required": ["schema_version", "target", "access", "engines"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "target":         { "type": "object" },
    "access":         { "type": "object" },
    "engines": {
      "type": "object",
      "required": ["vme", "vne"],
      "properties": {
        "vne": {
          "type": "object",
          "required": ["status", "mode", "started_at", "completed_at"],
          "properties": {
            "status":           { "type": "string", "enum": ["success", "failure"] },
            "mode":             { "type": "string", "enum": ["deploy", "join"], "default": "deploy" },
            "version":          { "type": "string" },
            "started_at":       { "type": "string", "format": "date-time" },
            "completed_at":     { "type": "string", "format": "date-time" },
            "duration_seconds": { "type": "number", "minimum": 0 },

            "provisioner":      { "type": "string", "minLength": 1 },

            "opnsense": {
              "type": "object",
              "required": ["vm_ip", "vmid", "api_endpoint", "version"],
              "properties": {
                "vm_ip":        { "type": "string", "format": "ipv4" },
                "vmid":         { "type": "integer", "minimum": 100 },
                "api_endpoint": { "type": "string", "format": "uri" },
                "version":      { "type": "string" }
              }
            },

            "vlans": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name", "cidr", "gateway"],
                "properties": {
                  "id":         { "type": "integer", "minimum": 1, "maximum": 4094 },
                  "name":       { "type": "string", "minLength": 1 },
                  "cidr":       { "type": "string" },
                  "gateway":    { "type": "string", "format": "ipv4" },
                  "dhcp_range": {
                    "type": "array",
                    "items": { "type": "string", "format": "ipv4" },
                    "minItems": 2,
                    "maxItems": 2
                  }
                }
              }
            },

            "dns": {
              "type": "object",
              "required": ["server", "domain", "upstream"],
              "properties": {
                "server":   { "type": "string", "format": "ipv4" },
                "domain":   { "type": "string" },
                "upstream": { "type": "array", "items": { "type": "string" } }
              }
            },

            "verification": {
              "type": "object",
              "required": ["passed", "checks"],
              "properties": {
                "passed": { "type": "boolean", "const": true,
                            "description": "VNE only writes its manifest when verification fully passed." },
                "checks": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            },

            "proxmox_host": {
              "type": "object",
              "properties": {
                "ip":       { "type": "string" },
                "hostname": { "type": "string" }
              }
            },

            "joined_network": {
              "type": "object",
              "description": "Populated when mode=join. Records the observed network state and which router adapter handled the join.",
              "required": ["adapter", "gateway"],
              "properties": {
                "mode":      { "type": "string", "const": "join" },
                "adapter":   { "type": "string", "minLength": 1,
                               "description": "Router adapter slug used (unmanaged, opnsense, ...)." },
                "gateway": {
                  "type": "object",
                  "required": ["ip"],
                  "properties": {
                    "ip":           { "type": "string" },
                    "vendor":       { "type": "string" },
                    "product":      { "type": "string" },
                    "version":      { "type": "string" },
                    "confidence":   { "type": "number", "minimum": 0, "maximum": 1 },
                    "managed":      { "type": "boolean" },
                    "api_endpoint": { "type": "string" }
                  }
                },
                "dns": {
                  "type": "object",
                  "properties": {
                    "resolvers":      { "type": "array", "items": { "type": "string" } },
                    "search_domains": { "type": "array", "items": { "type": "string" } }
                  }
                },
                "observed_cidrs": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "observed_vlans": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "observed_services": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "discovery_report": {
                  "type": "string",
                  "description": "Path or filename of the JSON discovery report this join was based on."
                },
                "live": {
                  "type": "object",
                  "description": "Adapter-specific live state pulled from the router API (when credentials were provided)."
                }
              }
            },

            "capabilities": {
              "type": "array",
              "description": "Flat list of capability flags VSE/VLE consume to gate features.",
              "items": {
                "type": "object",
                "required": ["name", "available"],
                "properties": {
                  "name":      { "type": "string" },
                  "available": { "type": "boolean" },
                  "reason":    { "type": "string" }
                }
              }
            }
          },

          "allOf": [
            {
              "if": { "properties": { "mode": { "const": "deploy" } }, "required": ["mode"] },
              "then": {
                "required": ["provisioner", "opnsense", "vlans", "dns", "verification"]
              }
            },
            {
              "if": { "properties": { "mode": { "const": "join" } }, "required": ["mode"] },
              "then": {
                "required": ["joined_network", "capabilities"]
              }
            }
          ],

          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
