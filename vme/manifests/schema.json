{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://velocit.ee/schemas/vme/manifest/1.0",
  "title": "VME Handoff Manifest",
  "description": "Structured handoff manifest produced by VME on successful provisioning.",
  "type": "object",
  "required": [
    "schema_version",
    "vme_version",
    "status",
    "hostname",
    "ip",
    "os",
    "os_version",
    "hardware",
    "ssh_host_key_fingerprint",
    "deployed_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Version of this manifest schema."
    },
    "vme_version": {
      "type": "string",
      "description": "VME release that produced this manifest."
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure"],
      "description": "Deployment outcome."
    },
    "failure_reason": {
      "type": "string",
      "description": "Human-readable reason for failure. Required when status is 'failure'."
    },
    "hostname": {
      "type": "string",
      "description": "Provisioned hostname."
    },
    "ip": {
      "type": "string",
      "format": "ipv4",
      "description": "Static IP assigned to the provisioned machine."
    },
    "os": {
      "type": "string",
      "enum": ["proxmox-ve", "ubuntu-server"],
      "description": "Operating system installed."
    },
    "os_version": {
      "type": "string",
      "description": "Resolved version string (e.g. '8.2-1', '24.04')."
    },
    "hardware": {
      "type": "object",
      "required": ["cpu", "ram_mb", "disks", "nics"],
      "properties": {
        "cpu": {
          "type": "string",
          "description": "CPU model string."
        },
        "ram_mb": {
          "type": "integer",
          "minimum": 1,
          "description": "Total RAM in megabytes."
        },
        "disks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["device", "size_gb"],
            "properties": {
              "device": { "type": "string" },
              "size_gb": { "type": "number" }
            }
          }
        },
        "nics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "mac"],
            "properties": {
              "name": { "type": "string" },
              "mac": {
                "type": "string",
                "pattern": "^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$"
              }
            }
          }
        }
      }
    },
    "ssh_host_key_fingerprint": {
      "type": "string",
      "description": "SHA256 fingerprint of the provisioned machine's SSH host key."
    },
    "deployed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of deployment completion."
    }
  },
  "if": {
    "properties": { "status": { "const": "failure" } }
  },
  "then": {
    "required": ["failure_reason"]
  }
}
